# Listen port (default 18081 — pick one that doesn't collide with jbai-proxy 18080).
GHE_PROXY_PORT=18081

# Path to the pool config. Default is ./tokens.json next to bin/.
# GHE_TOKENS_FILE=/home/apiadmin/github-enterprise-ai-proxy/tokens.json

# How often we sweep every PAT through GET /rate_limit. 5 min by default.
# GHE_QUOTA_REFRESH_MS=300000

# A PAT/seat is treated as "burnt" (skipped by routing) once used_pct
# crosses this. For Copilot pools used_pct = 1 - premium_interactions.
# percent_remaining/100 (the same number VSCode shows). Per-account
# override available via tokens.json `accounts[].usedPctCap`.
# GHE_QUOTA_BURNT_THRESHOLD=0.95

# Active account proactively swapped out at this used_pct. Same source
# as above. Per-account caps scale this proportionally (cap-0.05).
# GHE_QUOTA_PROACTIVE_SWAP_AT=0.9

# Default DESC = use the most-used non-burnt token first (drains existing
# quota before opening a fresh one). Set to "asc" for the opposite.
# GHE_FILL_DIRECTION=desc

# How tightly to pin the routing target. With 0.01 (=1pp) the same PAT
# stays selected until it has drifted more than 1 percentage point above
# the next candidate.
# GHE_ROUTING_HYSTERESIS=0.01

# Strategies: fill_first (default), round_robin, random.
# GHE_ROUTING_STRATEGY=fill_first

# Upstream timeout — must comfortably exceed the slowest model's latency.
# GHE_UPSTREAM_TIMEOUT_MS=600000

# Override the upstream hosts (e.g. for an enterprise-specific Models URL).
# GHE_REST_BASE=https://api.github.com
# GHE_MODELS_BASE=https://models.github.ai

# Where the on-disk quota cache is written (sibling CLIs read this).
# GHE_QUOTA_CACHE_FILE=/home/apiadmin/.ghe/quota-cache.json

# Optional Basic-auth on the /quota dashboard. Comma-separated user:pass.
# GHE_QUOTA_AUTH=admin:s3cret,bob:hunter2

# Enterprise slug used for SCIM polling, seat-assignment, and the
# enterprise license probe. (Carizon prod is `carizon-gh`.)
# GHE_EMU_ENTERPRISE_SLUG=carizon-gh

# PAT (classic) or fine-grained token with `manage_billing:copilot` scope.
# When set, the proxy probes /enterprises/<slug>/copilot/billing every
# QUOTA_REFRESH cycle and surfaces seat usage on /quota.json + the HTML
# dashboard. Also enables --copilot-seat in ghe-create-emu-user.cjs.
# Mint at https://github.com/settings/tokens/new?scopes=manage_billing:copilot
# Without this var the proxy works fine, the dashboard just shows a hint
# instead of seat numbers.
# GHE_COPILOT_ADMIN_PAT=ghp_…

# Same kind of PAT, additionally needs `scim:enterprise` so
# ghe-create-emu-user.cjs --wait-scim can poll for the SCIM push to land.
# Easiest path: mint one classic PAT with both scopes and set both vars
# to the same value.
# GHE_EMU_GITHUB_PAT=ghp_…

# Object Id of the GitHub Enterprise Managed User (OIDC) service principal
# in the Entra tenant that backs the carizon-gh OIDC SSO. Lookup once:
#   GET https://graph.microsoft.com/v1.0/servicePrincipals?$filter=appId eq '12f6db80-0741-4a7e-b9c5-b85d737b3a31'
# (the appId is the carizon-gh OIDC client_id visible on the SSO redirect
# URL). ghe-create-emu-user.cjs assigns its app role to every new user.
# GHE_EMU_SP_OBJECT_ID=…

# Entra tenant id that owns the EMU OIDC SP above. Visible on the same SSO
# redirect URL and inside the saved ~/.ghe/graph-token.json (`tenantId`).
# Used by ghe-mint-graph.cjs --refresh and create-emu-user — without it
# we fall through to the multi-tenant `organizations` endpoint, which only
# works while the access_token is still fresh.
# GHE_EMU_TENANT_ID=…

# Org slug that should receive the Copilot seat. The org-level seat-grant
# path (POST /orgs/{org}/copilot/billing/selected_users) bills at whatever
# Copilot product the org has attached. When the org has "Copilot Enterprise"
# attached (visible on /enterprises/{slug}/licensing/copilot as "Copilot:
# Enterprise" next to the org), this gives a real $39/seat/1000-premium-quota
# Enterprise seat. Without this var, ghe-create-emu-user.cjs --copilot-seat
# falls back to the enterprise-level endpoint, which on a Business-attached
# enterprise (like new carizon-gh setups) issues a $19/300-quota Business seat.
# Always set this for paying carizon-gh deployments.
# GHE_EMU_ASSIGN_ORG=carizon-dev
